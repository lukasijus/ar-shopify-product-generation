{
  "name": "alwayslike-nail-tryon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "format": "prettier --write \"**/*.{css,html,js,json,ts,tsx}\" && uv run --project tools/nail-extractor black .",
    "shopify:download-press-ons": "node scripts/download-shopify-press-ons.mjs",
    "assets:strip-metadata": "node scripts/strip-png-private-metadata.mjs public",
    "assets:validate-nail-ratios": "python3 scripts/validate_nail_asset_ratios.py",
    "nails:score": "uv run --project tools/nail-extractor nail-extractor score",
    "nails:extract": "uv run --project tools/nail-extractor nail-extractor extract",
    "nails:prepare-roi-source": "uv run --project tools/nail-extractor nail-extractor prepare-roi-source",
    "nails:extract-roi": "uv run --project tools/nail-extractor nail-extractor extract-roi",
    "nails:approve": "uv run --project tools/nail-extractor nail-extractor approve",
    "nails:format": "uv run --project tools/nail-extractor black .",
    "nails:test": "uv run --project tools/nail-extractor pytest"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mediapipe/tasks-vision": "^0.10.22-rc.20250304",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.6",
    "vitest": "^4.0.15"
  }
}
